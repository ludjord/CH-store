# ============================================================
# CHSTORE — Environment Variables Template
# Salin file ini ke .env (lokal) atau isi di Vercel Dashboard
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
# Pastikan IP 0.0.0.0/0 sudah diizinkan di MongoDB Atlas Network Access
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret (gunakan string acak minimal 32 karakter)
JWT_SECRET=ganti_dengan_secret_yang_sangat_panjang_dan_acak

# Email (SMTP Gmail — gunakan Google App Password, bukan password akun biasa)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
FROM_NAME=CHSTORE Admin
FROM_EMAIL=email@gmail.com
